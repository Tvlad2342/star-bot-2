# Настройки бота
BOT_NAME=star bot
BOT_VERSION=2.0
DATABASE_PATH=database.db

# ===== НАСТРОЙКИ ЛОГИРОВАНИЯ =====
LOG_LEVEL=INFO                    # Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_TO_FILE=true                   # Сохранять логи в файл
LOG_MAX_DAYS=7                     # Хранить логи N дней
LOG_DIR=logs                       # Папка для логов

# ===== НАСТРОЙКИ ПРОИЗВОДИТЕЛЬНОСТИ =====
CACHE_TTL=300                      # Время жизни кэша в секундах (5 минут)
SLOW_QUERY_THRESHOLD=500           # Порог медленного запроса в мс
MAX_USERS_CACHE=1000                # Максимальное количество пользователей в кэше

# ===== НАСТРОЙКИ ОТЧЕТОВ =====
DEFAULT_NORM=5                      # Норма инвайтов по умолчанию
DEFAULT_BONUS=50                     # Бонус по умолчанию в процентах
MAX_BONUS=1000                       # Максимальный бонус в процентах

# ===== НАСТРОЙКИ ЗАДАЧ =====
TASK_MIN_HOURS=1                     # Минимальное время на задачу в часах
TASK_MAX_HOURS=24                    # Максимальное время на задачу в часах
OVERDUE_CHECK_INTERVAL=300           # Проверка просроченных задач (сек)
UPCOMING_CHECK_INTERVAL=300           # Проверка приближающихся задач (сек)